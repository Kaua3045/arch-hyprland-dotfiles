{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 8,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": [
    "tray",
    "hyprland/workspaces",
    "custom/spotify"
  ],

  "modules-center": [
    "clock",
    "custom/weather"
  ],

  "modules-right": [
    "custom/notifications",
    "hyprland/language",
    "bluetooth",
    "network",
    "battery",
    "pulseaudio",
    "custom/power"
  ],

  "clock": {
    "format": "{:%H:%M | %b %d}",
    "tooltip-format": "<big>{:%A, %d de %B de %Y}</big>\n<tt>{calendar}</tt>",
    "on-click": "gsimplecal",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": 3,
      "on-scroll": 1,
      "format": {
        "monts": "<span color='#b0c6ff'><b>{}</b></span>",
        "days": "<span color='#e2e2e9'>{}</span>",
        "weeks": "<span color='#c5c6d0'><b>W{}</b></span>",
        "weekdays": "<span color='#b0c6ff'><b>{}</b></span>",
        "today": "<span color='#ffb4ab'><b>{}</b></span>"
      }
    }
  },

  "tray": {
    "icon-size": 14,
    "spacing": 10
  },

  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": false,
    "format": "{icon}",
    "on-click": "activate",
    "fortmat-icons": {
      "1": "i",
      "2": "ii",
      "3": "iii",
      "4": "iv",
      "5": "v",
      "6": "vi",
      "7": "vii",
      "8": "viii",
      "9": "ix",
      "10": "x"
    }
  },

  "custom/weather": {
        "format": "{}",
        "return-type": "json",
        "exec": ".config/waybar/scripts/weather.sh",
        "interval": 600
    },

  "custom/spotify": {
    "exec": "~/.config/waybar/scripts/spotify.sh",
    "interval": 2,
    "return-type": "text",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },

  "custom/notifications": {
    "format": "οÉ≥",
    "tooltip": false,
    "on-click": "swaync-client -t",
    "on-click-right": "swaync-client -d"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "σΑùü",
    "format-icons": {
      "default": ["οÄΠ", "οÄß", "οÄ®"]
    },
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "ο΅Ϊ  {bandwidthDownBytes}",
    "format-ethernet": "σΑ¨½ {bandwidthDownBytes}",
    "format-disconnected": "σΑ•Σ offline",
    "interval": 1
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-critical": "σΑ²É {capacity}%",
    "format-charging": "σΑ²³ {capacity}%",
    "format-plugged": "σΑ²³ {capacity}%",
    "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
    "tooltip": true
  },

  "bluetooth": {
    "format": "σΑ²·",
    "format-connected": "σΑ²· {num_connections}",
    "tooltip-format": "{device_alias}",
    "on-click": "blueman-manager"
  },

  "custom/power": {
    "format": "οÄë",
    "tooltip": false,
    "on-click": "pkill wlogout || wlogout &"
  },

  "hyprland/language": {
    "format": {}
  }
}
