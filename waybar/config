{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 8,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": [
    "clock",
    "custom/weather",
    "tray",
    "hyprland/workspaces"
  ],

  "modules-center": [
    "custom/spotify"
  ],

  "modules-right": [
    "custom/notifications",
    "hyprland/language",
    "pulseaudio",
    "custom/power"
  ],

  "clock": {
    "format": " {:%H:%M}",
    "tooltip-format": "{:%A, %d de %B de %Y}"
  },

  "tray": {
    "icon-size": 14,
    "spacing": 10
  },

  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": false,
    "format": "{name}",
    "on-click": "activate"
  },

  "custom/weather": {
        "format": "{}",
        "return-type": "json",
        "exec": ".config/waybar/scripts/weather.sh",
        "interval": 600
    },

  "custom/spotify": {
    "exec": "~/.config/waybar/scripts/spotify.sh",
    "interval": 2,
    "return-type": "text",
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous"
  },

  "custom/notifications": {
    "format": "",
    "tooltip": false,
    "on-click": "swaync-client -t",
    "on-click-right": "swaync-client -d"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol"
  },

  "custom/power": {
    "format": "",
    "tooltip": false,
    "on-click": "pkill wlogout || wlogout &"
  },

  "hyprland/language": {
    "format": {}
  }
}
