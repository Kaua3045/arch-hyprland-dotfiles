{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 8,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 8,

    "modules-left": [
        "clock#small",
        "custom/notifications",
        "custom/spotify"
    ],

    "modules-center": [
        "hyprland/workspaces"
    ],

    "modules-right": [
        "custom/weather",
        "pulseaudio",
        "tray",
        "network",
        "custom/power"
    ],

    "clock#small": {
        "format": "{:%H:%M}",
        "tooltip-format": "{:%A, %d de %B de %Y}",
        "interval": 1
    },

    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": false,
        "format": "{name}",
        "on-click": "activate"
    },

    "custom/spotify": {
        "format": "{}",
        "return-type": "text",
        "exec": ".config/waybar/scripts/spotify.sh",
        "interval": 2,
        "on-click": "playerctl play-pause",
        "on-click-up": "playerctl next",
        "on-click-down": "playerctl previous",
        "max-length": 40,
        "escape": true
    },

    "custom/weather": {
        "format": "{}",
        "return-type": "text",
        "exec": ".config/waybar/scripts/weather.sh",
        "interval": 900,
        "tooltip": true,
        "exec-if": "ping -c 1 wttr.in >/dev/null 2>&1"
    },

    "custom/notifications": {
        "format": "icon notification",
        "tooltip": false,
        "on-click": "swaync-client -t",
        "on-click-right": "swayn-client -d"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "icon mute",
        "format-icons": {
            "default": ["iconsssss", "iconss", "iconsssssssss"]
        },
        "on-click": "pavucontrol"
    },

    "tray": {
        "icon-size": 14,
        "spacing": 10
    },

    "network": {
        "format-wifi": "icon {signalStrength}%",
        "format-ethernet": "cabo",
        "format-disconnected": "offline",
        "tooltip-format-wifi": "{essid\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}"
    },

    "custom/power": {
        "format": "icon power",
        "tooltip": false,
        "on-click": "sh -c 'pkill wlogout || setsid wlogout >/dev/null 2>&1 &'"
    }
}