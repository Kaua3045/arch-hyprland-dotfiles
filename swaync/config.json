{
    "positionX": "right",
    "positionY": "top",
    "layer": "overlay",
    "control-center-width": 420,
    "control-center-height": 720,
    "notification-window-width": 360,
    "timeout": 6,
    "timeout-low": 4,
    "timeout-critical": 0,
    "fit-to-screen": true,
    "keyboard-shortcuts": true,
    "image-visibility": "when-available",
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": true,
    "script-fail-notify": true,
    "widgets": [
        "title",
        "mpris",
        "dnd",
        "notifications"
    ],
    "widget-config": {
        "title": {
            "text": "Notifications",
            "clear-all-button": false
        },
        "dnd": {
            "text": "Do Not Disturb"
        },
        "mpris": {
            "image-size": 72,
            "image-radius": 14
        },
        "notifications": {
            "show-scrollbar": false
        }
    }
}